PORT=3000
NODE_ENV=development

MONGODB_URI=mongodb://localhost:27017/ilueats

JWT_SECRET=change-me
JWT_EXPIRES_IN=7d




CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Where Paystack redirects the browser after a hosted checkout (frontend route)
PAYSTACK_CALLBACK_URL=http://localhost:3001/checkout/payment/callback
# Redirect target for wallet top-ups initiated from the hosted checkout
PAYSTACK_WALLET_CALLBACK_URL=http://localhost:3001/wallet/callback


# SMS / OTP via Termii - https://accounts.termii.com  (Settings -> API)
# TERMII_SENDER_ID=N-Alert is Termii's shared DND-bypass sender: no CAC or
# sender-ID approval needed, works for OTP/transactional content only.
# Leave TERMII_API_KEY empty to disable SMS (OTP sends will be rejected cleanly).
SMS_PROVIDER=termii
TERMII_API_KEY=
TERMII_BASE_URL=https://api.ng.termii.com
TERMII_SENDER_ID=N-Alert
TERMII_CHANNEL=dnd
TERMII_OTP_TTL_MINUTES=10
TERMII_OTP_LENGTH=6

# WhatsApp - Meta Cloud API (https://developers.facebook.com/docs/whatsapp/cloud-api)
# Order updates are business-initiated, so they can only be sent as message
# TEMPLATES that you create and get approved in Meta Business Manager.
# WHATSAPP_PHONE_NUMBER_ID is the Phone Number ID from the API Setup page (NOT the
# phone number). Use a permanent System User token, not the 24h temporary one.
# Leave WHATSAPP_ACCESS_TOKEN empty to disable WhatsApp (sends are skipped cleanly).
WHATSAPP_PROVIDER=meta
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_GRAPH_VERSION=v21.0
WHATSAPP_LANGUAGE_CODE=en
# Names of the approved templates (must match Meta exactly, and the language above).
WHATSAPP_TEMPLATE_ORDER_PREPARED=order_prepared
WHATSAPP_TEMPLATE_RIDER_ASSIGNED=rider_assigned
WHATSAPP_TEMPLATE_ORDER_DELIVERED=order_delivered

# Google SMTP (Gmail/Workspace) - https://myaccount.google.com/apppasswords
# SMTP_USER must be a real Gmail/Workspace address; SMTP_PASS is a 16-char App Password
# (not your normal login password - App Passwords require 2FA enabled on the account).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM_NAME=iluEats
MAIL_FROM_EMAIL=
MAIL_REPLY_TO=
MAIL_SUPPORT_EMAIL=support@ilueats.com
MAIL_SITE_URL=https://ilueats.com
# Where new-order notifications go. Unset = admin notifications are skipped.
MAIL_ADMIN_EMAIL=
MAIL_ADMIN_URL=https://admin.ilueats.com

# --- Address autocomplete (Google Places API "New") ---
# Enable BOTH "Places API (New)" and "Geocoding API" in Google Cloud (the latter
# powers "use my current location" reverse geocoding), and create an API key with
# billing enabled. Keep this key SERVER-SIDE only (it is never sent to the
# browser). Leave GOOGLE_MAPS_API_KEY empty to disable address search cleanly
# (the /geocoding endpoints return 503 and the UI falls back to manual entry).
GEOCODING_PROVIDER=google
GOOGLE_MAPS_API_KEY=
# Bias + restrict results to the service area so short queries surface local
# streets/landmarks. Center defaults to Ilisan-Remo; radius is in metres.
GEOCODING_BIAS_LAT=6.8944
GEOCODING_BIAS_LNG=3.7186
GEOCODING_BIAS_RADIUS_M=8000
# false (default) = bias results toward the area but still show matches outside
# it; the delivery guarantee is enforced on the picked coordinates via the
# `inServiceArea` flag. true = hard-limit autocomplete to the circle, which for
# short local queries makes Google return almost nothing (much worse picker).
GEOCODING_RESTRICT_TO_AREA=false
# When autocomplete returns FEWER than this many results, fall back to full-text
# search and merge, so a weak/empty local query still surfaces the real street.
GEOCODING_TEXT_SEARCH_FALLBACK_THRESHOLD=3
# The area appended to that fallback query so sparse local terms resolve. Empty
# disables the hint (the fallback still runs on the raw query).
GEOCODING_TEXT_SEARCH_HINT=Ilishan-Remo, Ogun State
GEOCODING_REGION_CODE=ng
GEOCODING_LANGUAGE_CODE=en
